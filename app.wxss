page {
  background: #f5f7fa;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 126rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.muted {
  color: #6b7280;
  font-size: 26rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #e7f6f4;
  color: #0b7a75;
}

.danger {
  color: #dc2626;
}

.warning {
  color: #d97706;
}

.success {
  color: #059669;
}


