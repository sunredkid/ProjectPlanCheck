<view class="page">
  <view class="title-row">
    <view class="title">电气参数库</view>
    <view class="action-btns">
      <button size="mini" class="top-action-btn" bindtap="toggleTemplateMenu">模板</button>
      <button size="mini" class="top-action-btn" bindtap="toggleBatchMode">{{batchMode ? '取消批量' : '批量'}}</button>
      <button size="mini" class="top-action-btn" bindtap="openCompare">对比</button>
    </view>
  </view>

  <!-- Template Menu -->
  <view wx:if="{{showTemplateMenu}}" class="card template-menu">
    <view class="section-label">参数模板</view>
    <view wx:if="{{templates.length === 0}}" class="muted">暂无保存的模板。加载设备参数后可"保存为模板"。</view>
    <view wx:for="{{templates}}" wx:key="id" class="tpl-item">
      <view class="tpl-name">{{item.name}}</view>
      <view class="tpl-meta muted">{{item.params.length}}个参数 · {{item.sourceDevice}}</view>
      <view class="tpl-actions">
        <button size="mini" class="ghost-btn small" data-id="{{item.id}}" bindtap="applyTemplate">套用</button>
        <button size="mini" class="ghost-btn small danger" data-id="{{item.id}}" bindtap="deleteTemplate">删除</button>
      </view>
    </view>
    <view class="tpl-footer">
      <button size="mini" class="main-btn" bindtap="saveAsTemplate">保存当前为模板</button>
    </view>
  </view>

  <view class="subtitle">默认按设备查，也可以按参数找相似设备</view>

  <view class="search card">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索项目 / 设备 / 型号 / 参数" />
    <view wx:if="{{activeMode === 'param'}}" class="advanced-toggle" bindtap="toggleAdvanced">
      {{showAdvanced ? '收起' : '高级筛选'}}
    </view>
  </view>

  <view wx:if="{{activeMode === 'param' && showAdvanced}}" class="card advanced-filters">
    <input class="search-input" value="{{paramKeyword}}" bindinput="onParamKeywordInput" placeholder="参数名关键词" />
    <input class="search-input" value="{{valueKeyword}}" bindinput="onValueKeywordInput" placeholder="参数值关键词" />
    <input class="search-input" value="{{remarkKeyword}}" bindinput="onRemarkKeywordInput" placeholder="备注关键词" />
    <input class="search-input" value="{{categoryFilter}}" bindinput="onCategoryInput" placeholder="按分类筛选（精确匹配）" />
    <button size="mini" class="reset-btn" bindtap="resetFilters">重置筛选</button>
  </view>

  <view class="modes">
    <view
      wx:for="{{modes}}"
      wx:key="key"
      class="mode {{activeMode === item.key ? 'active' : ''}}"
      data-value="{{item.key}}"
      bindtap="switchMode"
    >
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{devices.length === 0}}" class="empty-state">
    <view class="empty-title">暂无匹配参数</view>
    <view class="empty-desc">可更换查询方式或搜索关键词。</view>
  </view>

  <!-- Batch Actions Bar -->
  <view wx:if="{{batchMode}}" class="batch-bar">
    <view class="batch-info">已选 {{batchSelectedCount}} 台</view>
    <button size="mini" class="batch-action-btn primary" bindtap="batchDisable">批量停用设备</button>
    <button size="mini" class="batch-action-btn warning" bindtap="batchDisableParams">批量停用参数</button>
  </view>

  <view wx:for="{{devices}}" wx:key="rowKey" class="card param-card {{batchMode ? 'batch-card' : ''}} {{batchMode && batchSelected[item.id] ? 'batch-selected' : ''}}">
    <view wx:if="{{batchMode}}" class="batch-check" data-id="{{item.id}}" bindtap="toggleBatchSelect">
      <view class="check-box {{batchSelected[item.id] ? 'checked' : ''}}">{{batchSelected[item.id] ? '✓' : ''}}</view>
    </view>
    <view class="device-no">{{item.deviceNo}}</view>
    <view class="device-name">{{item.project}}</view>
    <view class="muted">型号：{{item.model}}</view>
    <view wx:if="{{activeMode === 'device'}}">
      <view class="param-line">风量：{{item.airVolume}}</view>
      <view class="param-line">PLC：{{item.plc}}</view>
      <view class="param-line">点位：{{item.points}}</view>
    </view>
    <view wx:else class="param-match">
      <view class="param-name">{{item.paramName}}</view>
      <view class="param-value">{{item.paramValue}}{{item.paramUnit}}</view>
      <view class="param-line">分组：{{item.category}}</view>
      <view wx:if="{{item.remark}}" class="muted">备注：{{item.remark}}</view>
    </view>
    <button size="mini" class="main-btn" data-id="{{item.id}}" bindtap="openParam">查看参数</button>
  </view>
</view>
<bottom-nav />
