<view class="page">
  <view class="card hero">
    <view class="label">Import Logs</view>
    <view class="title">Excel 导入日志</view>
    <view class="muted">当前阶段日志来自运行时 mock 数据，重新编译后不会持久保留。</view>
  </view>

  <view class="card filter-card">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索日志编号、状态、时间、统计数量" />
    <view class="filters">
      <view
        wx:for="{{statusFilters}}"
        wx:key="key"
        class="filter {{activeStatus === item.key ? 'active' : ''}}"
        data-value="{{item.key}}"
        bindtap="switchStatus"
      >{{item.label}}</view>
    </view>
    <view class="muted">共 {{total}} 条记录</view>
  </view>

  <view wx:if="{{!logs.length}}" class="card empty">
    <view class="empty-title">暂无导入日志</view>
    <view class="muted">完成一次确认导入后，这里会显示项目、设备、任务和行数统计。</view>
  </view>

  <view wx:for="{{logs}}" wx:key="id" class="card log-card">
    <view class="log-top">
      <view>
        <view class="log-id">{{item.id}}</view>
        <view class="muted">{{item.createdAt}}</view>
      </view>
      <view class="tag">{{item.status}}</view>
    </view>
    <view class="summary-grid">
      <view>
        <view class="num">{{item.projectCount}}</view>
        <view class="muted">项目</view>
      </view>
      <view>
        <view class="num">{{item.deviceCount}}</view>
        <view class="muted">设备</view>
      </view>
      <view>
        <view class="num">{{item.taskCount}}</view>
        <view class="muted">任务</view>
      </view>
      <view>
        <view class="num">{{item.rowCount}}</view>
        <view class="muted">行数</view>
      </view>
    </view>
  </view>

  <button wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">加载更多</button>
  <bottom-nav />
</view>
