<view class="page">
  <view class="header">
    <view>
      <view class="title">用户管理</view>
      <view class="subtitle">维护手机号、业务部门、后台权限角色和历史标记</view>
    </view>
    <button size="mini" class="main-btn" bindtap="addUser">新增用户</button>
  </view>

  <view class="search card">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索姓名、手机号、部门、角色" />
  </view>

  <view wx:if="{{users.length === 0}}" class="empty-state">
    <view class="empty-title">暂无匹配用户</view>
    <view class="empty-desc">可调整关键词或新增用户。</view>
  </view>

  <view wx:for="{{users}}" wx:key="id" class="card user-card">
    <view class="user-top">
      <view>
        <view class="user-name">{{item.name}}</view>
        <view class="muted">{{item.phone}}</view>
      </view>
      <view class="tag {{item.status === '停用' ? 'disabled' : ''}}">{{item.status}}</view>
    </view>
    <view class="info-grid">
      <view>部门：{{item.department}}</view>
      <view>角色：{{item.role}}</view>
      <view>历史主管标记：{{item.isManager ? '是' : '否'}}</view>
    </view>
    <view class="actions">
      <button size="mini" class="ghost-btn" data-id="{{item.id}}" bindtap="editUser">编辑</button>
      <button size="mini" class="danger-btn" data-id="{{item.id}}" bindtap="toggleStatus">{{item.status === '启用' ? '停用' : '启用'}}</button>
    </view>
  </view>
</view>
<bottom-nav />
