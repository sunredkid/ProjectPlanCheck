.label {
  color: #0b7a75;
  font-size: 24rpx;
  font-weight: 800;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  margin: 8rpx 0 12rpx;
}

.state-card {
  padding: 40rpx 28rpx;
  text-align: center;
}

.state-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.field {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.field:last-child {
  border-bottom: none;
}

.field-label {
  color: #374151;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 25rpx;
}

.chip.active {
  background: #0b7a75;
  color: #ffffff;
}

.selected-devices {
  margin-top: 12rpx;
  color: #0b7a75;
  font-size: 26rpx;
  line-height: 1.5;
}

.picker-value,
.textarea {
  background: #f9fafb;
  border-radius: 14rpx;
  padding: 18rpx;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  box-sizing: border-box;
}

.submit-btn {
  background: #0b7a75;
  color: #ffffff;
  border-radius: 999rpx;
  margin: 10rpx 0 28rpx;
}

.list-title {
  margin-top: 12rpx;
}

.dispatch-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dispatch-name {
  font-size: 32rpx;
  font-weight: 800;
}

.dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 1200;
  background: rgba(17, 24, 39, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.device-dialog {
  width: 100%;
  max-height: 76vh;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.device-list {
  max-height: 46vh;
}

.device-check {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid #eef2f7;
  color: #111827;
  font-size: 28rpx;
}

.device-check.checked {
  color: #0b7a75;
  font-weight: 700;
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  border: 2rpx solid #d1d5db;
  background: #ffffff;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
  box-sizing: border-box;
}

.device-check.checked .check-box {
  background: #0b7a75;
  border-color: #0b7a75;
}

.dialog-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 22rpx;
  background: #ffffff;
}
