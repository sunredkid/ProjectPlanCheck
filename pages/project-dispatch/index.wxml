<view class="page">
  <view wx:if="{{loadError}}" class="card state-card">
    <view class="state-title">项目派单加载失败</view>
    <view class="muted">{{loadError}}</view>
  </view>

  <block wx:else>
  <view class="card hero">
    <view class="label">项目派单</view>
    <view class="title">{{project.projectNo}} {{project.projectName}}</view>
    <view class="muted">进度管理员将任务派到部门，部门管理员再派到具体员工。</view>
  </view>

  <view class="card">
    <view class="section-title">派单信息</view>
    <view class="field">
      <view class="field-label">设备范围</view>
      <view class="chips">
        <view class="chip {{form.device === '全部设备' ? 'active' : ''}}" bindtap="chooseAllDevices">全部设备</view>
        <view class="chip {{selectedDevices.length ? 'active' : ''}}" bindtap="openDeviceDialog">按台派单</view>
      </view>
      <view wx:if="{{selectedDevices.length}}" class="selected-devices">{{form.device}}</view>
    </view>

    <view class="field">
      <view class="field-label">工序</view>
      <view class="chips">
        <view wx:for="{{processes}}" wx:key="*this" class="chip {{form.process === item ? 'active' : ''}}" data-field="process" data-value="{{item}}" bindtap="chooseOption">{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">负责部门</view>
      <view class="chips">
        <view wx:for="{{departments}}" wx:key="*this" class="chip {{form.department === item ? 'active' : ''}}" data-field="department" data-value="{{item}}" bindtap="chooseOption">{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">计划截止日期</view>
      <picker mode="date" value="{{form.plannedDueDate}}" bindchange="onDateChange">
        <view class="picker-value">{{form.plannedDueDate}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">备注</view>
      <textarea class="textarea" value="{{form.remark}}" bindinput="onRemarkInput" placeholder="可说明范围、注意事项、需要协作的部门" />
    </view>
  </view>

  <button class="submit-btn" bindtap="submitDispatch" loading="{{isSubmitting}}" disabled="{{isSubmitting}}">派到部门</button>

  <view class="section-title list-title">已派部门任务</view>
  <view wx:for="{{pendingDispatches}}" wx:key="rowKey" class="card dispatch-card">
    <view class="dispatch-top">
      <view>
        <view class="dispatch-name">{{item.process}}</view>
        <view class="muted">{{item.device}}</view>
      </view>
      <view class="tag">{{item.status}}</view>
    </view>
    <view class="muted">部门：{{item.department}}｜截止：{{item.due}}</view>
  </view>
  <view wx:if="{{showDeviceDialog}}" class="dialog-mask" bindtap="closeDeviceDialog">
    <view class="device-dialog" catchtap="noop">
      <view class="dialog-title">选择设备</view>
      <scroll-view scroll-y class="device-list">
        <view
          wx:for="{{deviceOptions}}"
          wx:key="no"
          class="device-check {{item.checked ? 'checked' : ''}}"
          data-index="{{index}}"
          bindtap="toggleDevice"
        >
          <view class="check-box">{{item.checked ? '✓' : ''}}</view>
          <text>{{item.no}}</text>
        </view>
      </scroll-view>
      <view class="dialog-actions">
        <button size="mini" class="ghost-btn" bindtap="closeDeviceDialog">取消</button>
        <button size="mini" class="main-btn" bindtap="confirmDeviceSelection">确认</button>
      </view>
    </view>
  </view>
  </block>
<bottom-nav />
</view>
