.title {
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.state-card {
  padding: 40rpx 28rpx;
  text-align: center;
}

.state-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.field {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.field:last-child {
  border-bottom: none;
}

.field-label {
  color: #374151;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.input,
.picker-value {
  background: #f9fafb;
  border-radius: 14rpx;
  padding: 18rpx;
  color: #1f2937;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input {
  height: 76rpx;
}

.input.readonly {
  color: #6b7280;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 25rpx;
}

.chip.active {
  background: #0b7a75;
  color: #ffffff;
}

.bottom-actions {
  position: sticky;
  bottom: 0;
  padding: 18rpx 0 28rpx;
  background: #f5f7fa;
}

.submit-btn {
  background: #0b7a75;
  color: #ffffff;
  border-radius: 999rpx;
}
