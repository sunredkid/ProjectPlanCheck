.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 22rpx;
}

.profile {
  display: flex;
  gap: 22rpx;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #0b7a75;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 28rpx;
  color: #6b7280;
  margin: 28rpx 0 12rpx;
}

.mock-user {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f9fafb;
  margin-bottom: 14rpx;
}

.mock-user.active {
  background: #e7f6f4;
}

.mock-name {
  font-size: 28rpx;
  font-weight: 700;
}

.selected {
  color: #0b7a75;
  font-size: 24rpx;
  font-weight: 700;
}

.menu {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  font-size: 30rpx;
}

.menu:last-child {
  border-bottom: none;
}

.release-note {
  background: #f9fafb;
}

.cloud-card {
  padding-bottom: 18rpx;
}

.cloud-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.cloud-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.cloud-badge {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #fef3c7;
  color: #d97706;
}

.cloud-badge.success {
  background: #dcfce7;
  color: #059669;
}

.cloud-grid {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}

.cloud-ops-toggle {
  display: inline-flex;
  margin-top: 4rpx;
  color: #0b7a75;
  font-size: 24rpx;
  font-weight: 700;
}

.cloud-row {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0;
  font-size: 24rpx;
}

.cloud-label {
  flex: 0 0 128rpx;
  color: #6b7280;
}

.cloud-value {
  flex: 1;
  color: #1f2937;
  word-break: break-all;
}

.cloud-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 18rpx;
}

.cloud-btn {
  margin: 0;
  border-radius: 8rpx;
}

.cloud-btn.primary {
  background: #0b7a75;
  color: #ffffff;
}

.cloud-health {
  align-items: flex-start;
}

.health-step {
  line-height: 1.6;
}


