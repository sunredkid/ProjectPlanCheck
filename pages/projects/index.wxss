.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  color: #6b7280;
  font-size: 26rpx;
  margin-top: 6rpx;
}

.header-actions {
  display: flex;
  gap: 12rpx;
}

button {
  margin: 0;
}

.main-btn {
  background: #0b7a75;
  color: #ffffff;
  border-radius: 999rpx;
}

.ghost-btn {
  background: #e7f6f4;
  color: #0b7a75;
  border-radius: 999rpx;
}

.search {
  padding: 22rpx 24rpx;
}

.search-input {
  font-size: 26rpx;
  color: #111827;
}

.filters {
  display: flex;
  gap: 12rpx;
  margin: 10rpx 0 22rpx;
}

.filter {
  padding: 10rpx 22rpx;
  background: #ffffff;
  border-radius: 999rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.filter.active {
  background: #0b7a75;
  color: #ffffff;
}

.empty-state {
  padding: 44rpx 28rpx;
  background: #ffffff;
  border-radius: 8rpx;
  text-align: center;
  color: #6b7280;
}

.empty-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
}

.project-top,
.project-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.project-no {
  color: #0b7a75;
  font-size: 28rpx;
  font-weight: 700;
}

.project-name {
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  color: #4b5563;
  font-size: 25rpx;
  margin: 22rpx 0;
}

.progress-row {
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.progress-bar {
  height: 16rpx;
  background: #e5e7eb;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: #0b7a75;
}

.status-line {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}


