.login-page {
  min-height: 100vh;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.subtitle {
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.form-card {
  padding: 28rpx;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  color: #374151;
  font-size: 26rpx;
  margin-bottom: 10rpx;
}

.input,
.picker-value {
  height: 82rpx;
  border-radius: 8rpx;
  background: #f9fafb;
  padding: 0 22rpx;
  font-size: 28rpx;
  color: #111827;
  display: flex;
  align-items: center;
}

.phone-btn,
.submit-btn {
  margin-top: 18rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.phone-btn {
  color: #0b7a75;
  background: #e7f6f4;
}

.submit-btn {
  color: #ffffff;
  background: #0b7a75;
}
