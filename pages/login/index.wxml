<view class="page login-page">
  <view class="title">登录绑定</view>
  <view class="subtitle">首次使用请绑定微信身份。提交后默认为临时用户，待管理员启用后按部门权限使用。</view>

  <view class="card form-card">
    <view class="field">
      <view class="label">姓名</view>
      <input class="input" value="{{name}}" bindinput="onNameInput" placeholder="请输入真实姓名" />
    </view>

    <view class="field">
      <view class="label">部门</view>
      <picker mode="selector" range="{{departmentNames}}" value="{{departmentIndex}}" bindchange="onDepartmentChange">
        <view class="picker-value">{{departmentName || '请选择部门'}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">手机号</view>
      <input class="input" type="number" value="{{phone}}" bindinput="onPhoneInput" placeholder="请输入手机号" />
    </view>

    <button class="phone-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">自动获取手机号</button>
    <button class="submit-btn" loading="{{submitting}}" bindtap="submitLogin">提交绑定</button>
  </view>
</view>
