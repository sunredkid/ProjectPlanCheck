.qb-no {
  color: #0b7a75;
  font-size: 28rpx;
  font-weight: 800;
}

.state-card {
  padding: 40rpx 28rpx;
  text-align: center;
}

.state-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.qb-title {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.45;
  margin: 12rpx 0 18rpx;
}

.hero-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.viewer-tip {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  color: #4b5563;
  font-size: 25rpx;
}

.paragraph {
  margin-bottom: 18rpx;
  color: #374151;
  font-size: 28rpx;
}

.field-title {
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.device-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.device-tag {
  padding: 10rpx 18rpx;
  background: #e7f6f4;
  color: #0b7a75;
  border-radius: 999rpx;
  font-size: 25rpx;
}

.empty-tip {
  color: #6b7280;
  font-size: 26rpx;
  padding: 12rpx 0;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f9fafb;
  border-radius: 14rpx;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: 18rpx;
}

.main-btn,
.ghost-btn,
.close-btn {
  margin: 0;
  border-radius: 999rpx;
}

.main-btn {
  background: #0b7a75;
  color: #ffffff;
}

.ghost-btn {
  background: #e7f6f4;
  color: #0b7a75;
}

.close-btn {
  background: #dc2626;
  color: #ffffff;
}

.log-row {
  display: flex;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.log-row:last-child {
  border-bottom: none;
}

.log-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #0b7a75;
  margin-top: 10rpx;
  flex: none;
}

.log-main {
  font-size: 27rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.bottom-actions {
  position: sticky;
  bottom: 0;
  display: grid;
  gap: 16rpx;
  padding: 18rpx 0 28rpx;
  background: #f5f7fa;
}

.bottom-actions.two {
  grid-template-columns: 1fr 1fr;
}

.bottom-actions.one {
  grid-template-columns: 1fr;
}


.assignee-list { margin-top: 4px; }
.assignee-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid #f5f5f5; }
.assignee-row:last-child { border-bottom: none; }
.assignee-name { font-size: 14px; color: #333; }
.assignee-status { font-size: 12px; padding: 2px 10px; border-radius: 10px; }
.assignee-status.done { background: #e8f5e9; color: #2e7d32; }
.assignee-status.doing { background: #e3f2fd; color: #1565c0; }
.assignee-status.pending { background: #fff3e0; color: #e65100; }

