.device-no {
  color: #0b7a75;
  font-size: 28rpx;
  font-weight: 800;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  margin: 8rpx 0 12rpx;
}

.device-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  color: #374151;
  font-size: 26rpx;
}

.device-meta view {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 10rpx 14rpx;
}

.viewer-tip {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.section-row,
.action-group,
.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-row {
  align-items: flex-start;
  gap: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  margin: 12rpx 0 8rpx;
}

.main-btn,
.ghost-btn {
  margin: 0;
  border-radius: 999rpx;
}

.main-btn {
  background: #0b7a75;
  color: #ffffff;
}

.ghost-btn {
  background: #e7f6f4;
  color: #0b7a75;
}

.action-group {
  gap: 12rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.sort-tip {
  background: #fff7ed;
}

.group-card {
  margin-bottom: 22rpx;
}

.group-header {
  background: #0b7a75;
  color: #ffffff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 22rpx 24rpx;
}

.group-header .muted {
  color: rgba(255, 255, 255, 0.76);
}

.group-title {
  font-size: 32rpx;
  font-weight: 800;
}

.group-pill {
  background: rgba(255, 255, 255, 0.18);
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
}

.group-body {
  background: #eef7f6;
  padding: 14rpx;
  border-radius: 0 0 20rpx 20rpx;
}

.param-card {
  margin-bottom: 14rpx;
  padding: 22rpx;
}

.param-card.dragging {
  border: 2rpx dashed #0b7a75;
  transform: scale(1.01);
}

.param-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1f2937;
  line-height: 1.35;
  padding-right: 18rpx;
  flex: 1;
}

.param-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.param-value-block {
  color: #0b7a75;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.5;
  margin-top: 14rpx;
  padding: 16rpx;
  background: #f0fdfa;
  border-radius: 14rpx;
  word-break: break-all;
  white-space: normal;
}

.drag-handle {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 800;
  flex: none;
}

.edit-btn {
  margin: 0;
  min-width: 96rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 18rpx;
  background: #e7f6f4;
  color: #0b7a75;
  border-radius: 999rpx;
  font-size: 24rpx;
  flex: none;
}

.read-tip {
  text-align: center;
}


.state-card { padding: 40rpx 28rpx; text-align: center; }
.state-title { color: #111827; font-size: 30rpx; font-weight: 700; margin-bottom: 10rpx; }
