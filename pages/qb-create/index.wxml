<view class="page">
  <view wx:if="{{loadError}}" class="card state-card">
    <view class="state-title">QB 创建加载失败</view>
    <view class="muted">{{loadError}}</view>
  </view>

  <block wx:else>
  <view class="card hero">
    <view class="label">新增 QB</view>
    <view class="title">{{project.projectNo}} {{project.projectName}}</view>
    <view class="muted">当前登录：{{currentUser.name}}｜{{currentUser.department}}</view>
    <view wx:if="{{!canCreate}}" class="warning-box">当前不是采购部账号，只能查看原型，不能提交。</view>
  </view>

  <view class="card">
    <view class="section-title">基础信息</view>
    <view class="field">
      <view class="field-label">QB单号 *</view>
      <input class="input" value="{{form.qbNo}}" data-field="qbNo" bindinput="setField" placeholder="请输入 QB 单号" />
    </view>

    <view class="field">
      <view class="field-label">异常类别</view>
      <view class="chips">
        <view wx:for="{{categories}}" wx:key="*this" class="chip {{form.category === item ? 'active' : ''}}" data-field="category" data-value="{{item}}" bindtap="chooseOption">{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">异常提出工序</view>
      <view class="chips">
        <view wx:for="{{raisedProcesses}}" wx:key="*this" class="chip {{form.raisedProcess === item ? 'active' : ''}}" data-field="raisedProcess" data-value="{{item}}" bindtap="chooseOption">{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">发生时间</view>
      <picker mode="date" value="{{form.occurredAt}}" data-field="occurredAt" bindchange="setField">
        <view class="picker-value">{{form.occurredAt}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">发生数量</view>
      <input class="input" type="number" value="{{form.quantity}}" data-field="quantity" bindinput="setField" />
    </view>
  </view>

  <view class="card">
    <view class="section-title">异常内容</view>
    <view class="field">
      <view class="field-label">异常描述 *</view>
      <textarea class="textarea" value="{{form.description}}" data-field="description" bindinput="setField" placeholder="描述发生了什么、影响范围、现场现象" />
    </view>
    <view class="field">
      <view class="field-label">异常原因</view>
      <textarea class="textarea small" value="{{form.reason}}" data-field="reason" bindinput="setField" placeholder="例如：核对疏忽" />
    </view>
    <view class="field">
      <view class="field-label">临时对策</view>
      <textarea class="textarea small" value="{{form.temporaryAction}}" data-field="temporaryAction" bindinput="setField" placeholder="例如：补购物料" />
    </view>
    <view class="field">
      <view class="field-label">长效对策</view>
      <textarea class="textarea small" value="{{form.longTermAction}}" data-field="longTermAction" bindinput="setField" placeholder="例如：加强核查" />
    </view>
    <button class="upload-btn" bindtap="uploadFile">上传图片 / 附件</button>
    <view wx:if="{{attachments.length}}" class="attachment-list">
      <view wx:for="{{attachments}}" wx:key="id" class="attachment-row">
        <view class="attachment-main" data-index="{{index}}" bindtap="previewAttachment">
          <view class="attachment-icon">{{item.icon}}</view>
          <view>
            <view class="attachment-name">{{item.name}}</view>
            <view class="att-cat-tag">{{item.category || "图纸"}}</view>
            <view wx:if="{{item.uploaded}}" class="muted cloud-mark">云已上传</view>
            <view wx:else class="muted">{{item.type === 'image' ? '点击预览图片' : '点击打开文件'}}</view>
          </view>
        </view>
        <button size="mini" class="remove-btn" data-index="{{index}}" bindtap="removeAttachment">移除</button>
      </view>
    </view>

    <view wx:if="{{isUploadingAtt}}" class="upload-progress">
      <view class="progress-text">正在上传... {{uploadProgress}}/{{uploadTotal}}</view>
      <progress percent="{{uploadProgress * 100 / uploadTotal}}" stroke-width="4" active />
    </view>
    <view wx:elif="{{attachments.length}}">
      <button size="mini" class="ghost-btn" bindtap="uploadAttachments" disabled="{{isUploadingAtt}}">云同步到云端</button>
    </view>
  </view>

  <view class="card">
    <view class="section-title">责任与关联</view>
    <view class="field">
      <view class="field-label">责任部门</view>
      <view class="chips">
        <view wx:for="{{departments}}" wx:key="*this" class="chip {{form.responsibleDepartment === item ? 'active' : ''}}" data-field="responsibleDepartment" data-value="{{item}}" bindtap="chooseOption">{{item}}</view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">当前负责人 *</view>
      <view class="chips">
        <view wx:for="{{availableUsers}}" wx:key="*this" class="chip {{form.currentOwner === item ? 'active' : ''}}" data-field="currentOwner" data-value="{{item}}" bindtap="chooseOption">{{item}}</view>
      </view>
      <view wx:if="{{availableUsers.length === 0}}" class="empty-tip">该部门暂无可选人员，请先到用户管理维护。</view>
    </view>

    <view class="field">
      <view class="field-label">关联设备（可多选）</view>
      <view class="device-list">
        <view wx:for="{{devices}}" wx:key="no" class="device-item {{item.checked ? 'active' : ''}}" data-index="{{index}}" bindtap="toggleDevice">
          {{item.no}}
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-actions">
    <button class="submit-btn" bindtap="submit" loading="{{isSubmitting}}" disabled="{{isSubmitting}}">创建 QB</button>
  </view>
  </block>
</view>
<bottom-nav />
