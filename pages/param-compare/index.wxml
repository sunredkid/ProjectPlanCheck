<view class="page">
  <view class="title">参数对比</view>
  <view class="subtitle">选择2-5台设备，并排对比参数值。差异值标红。</view>

  <view class="card">
    <view class="section-label">选择设备</view>
    <view class="device-grid">
      <view
        wx:for="{{allDevices}}"
        wx:key="id"
        class="device-chip {{item.selected ? 'selected' : ''}}"
        data-id="{{item.id}}"
        bindtap="toggleDevice"
      >
        {{item.deviceNo}}
        <text wx:if="{{item.selected}}" class="selected-mark">✓</text>
      </view>
    </view>
    <view wx:if="{{selectedIds.length > 0}}" class="sel-info">已选 {{selectedIds.length}} 台</view>
    <view class="compare-actions">
      <button size="mini" class="main-btn" bindtap="startCompare" disabled="{{selectedIds.length < 2}}">开始对比</button>
      <button size="mini" class="reset-btn" bindtap="resetCompare">重置</button>
      <button wx:if="{{showResult}}" size="mini" class="ghost-btn" bindtap="exportCSV">导出 CSV</button>
    </view>
  </view>

  <view wx:if="{{showResult && compareResult}}" class="result-section">
    <view class="diff-legend">
      <view class="legend-item"><view class="legend-dot diff-bg"></view> 值不同</view>
      <view class="legend-item"><view class="legend-dot same-bg"></view> 值一致</view>
      <view class="legend-item"><view class="legend-dot missing-bg"></view> 无数据</view>
    </view>

    <view wx:for="{{categories}}" wx:for-item="cat" wx:key="name" class="category-group">
      <view class="category-header" data-cat="{{cat.name}}" bindtap="toggleCategory">
        <view class="category-arrow">{{expandedCategories[cat.name] ? '▼' : '▶'}}</view>
        <view class="category-name">{{cat.name}}</view>
        <view class="category-count">{{cat.diffCount}}项差异</view>
      </view>

      <view wx:if="{{expandedCategories[cat.name]}}" class="compare-table">
        <view class="compare-row header-row">
          <view class="param-col">参数名</view>
          <view wx:for="{{compareResult.devices}}" wx:for-item="dev" wx:key="id" class="device-col">
            {{dev.deviceNo}}
            <view class="device-sub">{{dev.model}}</view>
          </view>
        </view>

        <block wx:for="{{compareResult.matrix}}" wx:for-item="row" wx:key="paramName">
          <view wx:if="{{row.category === cat.name}}" class="compare-row {{row.hasDiff ? 'diff-row' : ''}}">
            <view class="param-col">
              <view>{{row.paramName}}</view>
            </view>
            <view
              wx:for="{{row.values}}"
              wx:for-item="val"
              wx:key="index"
              class="device-col {{val.has ? '' : 'missing'}} {{val.isDiff ? 'diff-cell' : ''}}"
            >
              {{val.value}}{{val.unit}}
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
<bottom-nav />
