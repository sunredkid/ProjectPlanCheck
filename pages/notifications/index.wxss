.page { padding-bottom: 60px; }

.header-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 16px 16px 12px;
  border-bottom: 1px solid #f0f0f0;
}
.title { font-size: 18px; font-weight: 700; color: #333; }
.unread-badge {
  background: #fee2e2;
  color: #c62828;
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 10px;
  font-weight: 600;
}
.subscribe-btn {
  font-size: 11px;
  color: #1565c0;
  padding: 4px 10px;
  border-radius: 4px;
  border: 1px solid #1565c0;
}
.mark-all-btn {
  margin-left: auto;
  font-size: 12px;
  color: #0B7A75;
  padding: 4px 10px;
  border-radius: 4px;
  border: 1px solid #0B7A75;
}

.loading-card, .empty-card { padding: 40px; text-align: center; }
.empty-icon { font-size: 36px; margin-bottom: 8px; }

.notif-list { padding: 0; }
.notif-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 14px 16px;
  border-bottom: 1px solid #f5f5f5;
  position: relative;
}
.notif-item.unread { background: #f0faf9; }
.notif-icon { font-size: 22px; min-width: 28px; text-align: center; line-height: 1.3; }
.notif-body { flex: 1; min-width: 0; }
.notif-title { font-size: 14px; font-weight: 600; color: #333; margin-bottom: 2px; }
.notif-message { font-size: 12px; color: #555; line-height: 1.4; margin-bottom: 6px; }
.notif-meta { display: flex; align-items: center; gap: 8px; }
.notif-type-tag {
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 3px;
  background: #e8f5e9;
  color: #2e7d32;
}
.notif-time { font-size: 10px; }
.notif-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #c62828;
  position: absolute;
  right: 16px;
  top: 18px;
}