.header-bar { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 12px; }
.header-bar .main-btn { flex: none; margin-top: 2px; }
.perm-matrix-card { padding: 0; overflow: hidden; }
.perm-scroll { overflow-x: auto; }
.perm-table { min-width: 600px; }
.perm-row { display: flex; border-bottom: 1px solid #f0f0f0; }
.perm-row.perm-header { font-weight: 600; background: #f8f8f8; }
.perm-row:last-child { border-bottom: none; }
.perm-label-col { flex: 1.2; min-width: 110px; padding: 10px 8px; font-size: 13px; }
.perm-role-col { flex: 1; min-width: 70px; padding: 10px 4px; font-size: 12px; text-align: center; }
.perm-dot { display: inline-block; width: 22px; height: 22px; line-height: 22px; border-radius: 11px; font-size: 12px; text-align: center; }
.perm-dot.granted { background: #e8f5e9; color: #2e7d32; }
.perm-dot.denied { background: #f5f5f5; color: #ccc; }
.note { margin-top: 12px; }

.scope-table { margin-top: 8px; }
.scope-row { display: flex; align-items: center; padding: 8px 12px; border-bottom: 1px solid #f0f0f0; font-size: 13px; }
.scope-header { font-weight: 600; color: #555; background: #f9fafb; }
.scope-role-col { flex: 1; }
.scope-value-col { min-width: 80px; text-align: center; }
.scope-badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
.scope-all { background: #e8f5e9; color: #2e7d32; }
.scope-department { background: #e3f2fd; color: #1565c0; }
.scope-project { background: #fff8e1; color: #f57f17; }
.scope-self { background: #fce4ec; color: #c62828; }
.scope-note { margin-top: 12px; font-size: 11px; line-height: 1.5; }
