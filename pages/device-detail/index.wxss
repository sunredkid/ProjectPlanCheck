.device-no {
  color: #0b7a75;
  font-size: 28rpx;
  font-weight: 700;
}

.state-card {
  padding: 40rpx 28rpx;
  text-align: center;
}

.state-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.device-area {
  font-size: 38rpx;
  font-weight: 800;
  margin: 8rpx 0 12rpx;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin: 10rpx 0 20rpx;
}

.tab {
  padding: 10rpx 22rpx;
  background: #ffffff;
  border-radius: 999rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.tab.active {
  background: #0b7a75;
  color: #ffffff;
}

.row,
.owner-row,
.param-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.process-name,
.param-name {
  font-size: 30rpx;
  font-weight: 700;
}

.detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  color: #4b5563;
  font-size: 25rpx;
  margin: 18rpx 0;
}

.late-finish {
  color: #dc2626;
  font-weight: 700;
}

.main-btn {
  margin: 0;
  background: #0b7a75;
  color: #ffffff;
  border-radius: 999rpx;
}

.device-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 18rpx;
}

.ghost-btn,
.warn-btn,
.danger-btn {
  margin: 0;
  border-radius: 999rpx;
}

.ghost-btn {
  background: #e7f6f4;
  color: #0b7a75;
}

.warn-btn {
  background: #fef3c7;
  color: #92400e;
}

.danger-btn {
  background: #fee2e2;
  color: #b91c1c;
}

.qb-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 10rpx 0 14rpx;
}

.param-value {
  color: #0b7a75;
  font-weight: 700;
  font-size: 30rpx;
}

.full-btn {
  width: 100%;
  margin-top: 8rpx;
}


