<view class="page">
  <view wx:if="{{loadError}}" class="card state-card">
    <view class="state-title">设备详情加载失败</view>
    <view class="muted">{{loadError}}</view>
  </view>

  <block wx:else>
  <view class="card hero">
    <view class="device-no">{{device.deviceNo}}</view>
    <view class="device-area">{{device.area}}</view>
    <view class="muted">项目：{{device.project}}</view>
    <view class="muted">型号：{{device.model}}</view>
    <view class="muted">状态：{{device.status}}</view>
    <view class="device-actions">
      <button size="mini" class="ghost-btn" bindtap="editDevice" disabled="{{isBusy}}">编辑设备</button>
      <button wx:if="{{device.status !== '停用'}}" size="mini" class="warn-btn" bindtap="disableDevice" loading="{{isDisabling}}" disabled="{{isBusy}}">停用</button>
      <button size="mini" class="danger-btn" bindtap="deleteDevice" loading="{{isDeleting}}" disabled="{{isBusy}}">删除</button>
    </view>
  </view>

  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="*this"
      class="tab {{activeTab === item ? 'active' : ''}}"
      data-value="{{item}}"
      bindtap="switchTab"
    >
      {{item}}
    </view>
  </view>

  <block wx:if="{{activeTab === tabs[0]}}">
    <view wx:if="{{processes.length === 0}}" class="card state-card">
      <view class="state-title">暂无工序</view>
      <view class="muted">当前设备还没有工序计划，可从项目派单或导入模板生成。</view>
    </view>

    <view wx:for="{{processes}}" wx:key="name" class="card process-card">
      <view class="row">
        <view class="process-name">{{item.name}}</view>
        <view class="tag">{{item.status}}</view>
      </view>
      <view class="detail-grid">
        <view>负责人：{{item.owner}}</view>
        <view>计划完成：{{item.due}}</view>
        <view>实际开始：{{item.start}}</view>
        <view>实际完成：<text class="{{item.actualFinishTone}}">{{item.finish}}</text></view>
      </view>
      <button wx:if="{{item.canSubmitProgress}}" size="mini" class="main-btn" data-process="{{item.name}}" bindtap="submitProgress">提交进度</button>
    </view>
  </block>

  <block wx:elif="{{activeTab === tabs[1]}}">
    <view wx:if="{{processes.length === 0}}" class="card state-card">
      <view class="state-title">暂无负责人</view>
      <view class="muted">当前设备还没有工序负责人。</view>
    </view>

    <view wx:for="{{processes}}" wx:key="name" class="card owner-row">
      <view>
        <view class="process-name">{{item.name}}</view>
        <view class="muted">{{item.owner}}｜{{item.phone}}</view>
      </view>
      <view class="tag">{{item.status}}</view>
    </view>
  </block>

  <block wx:elif="{{activeTab === 'QB'}}">
    <view wx:if="{{qbList.length === 0}}" class="card state-card">
      <view class="state-title">暂无 QB</view>
      <view class="muted">当前设备所属项目暂无 QB 记录。</view>
    </view>

    <view wx:for="{{qbList}}" wx:key="qbNo" class="card">
      <view class="device-no">{{item.qbNo}}</view>
      <view class="qb-title">{{item.title}}</view>
      <view class="muted">当前负责人：{{item.owner}}</view>
      <view class="row">
        <view class="tag">{{item.status}}</view>
        <button size="mini" class="main-btn" data-no="{{item.qbNo}}" bindtap="openQb">查看详情</button>
      </view>
    </view>
  </block>

  <block wx:else>
    <view wx:if="{{params.length === 0}}" class="card state-card">
      <view class="state-title">暂无参数</view>
      <view class="muted">当前设备还没有维护电气参数。</view>
    </view>

    <view wx:for="{{params}}" wx:key="name" class="card param-row">
      <view class="param-name">{{item.name}}</view>
      <view class="param-value">{{item.value}} {{item.unit}}</view>
    </view>
    <button class="main-btn full-btn" bindtap="openParams">查看参数树</button>
    <button class="ghost-btn full-btn" bindtap="openParamCompare">参数对比</button>
  </block>
  </block>
</view>
<bottom-nav />
