<view class="page">
  <view class="header">
    <view>
      <view class="title">部门管理</view>
      <view class="subtitle">维护部门、主管和显示顺序</view>
    </view>
    <button size="mini" class="main-btn" bindtap="addDepartment">新增部门</button>
  </view>

  <view class="search card">
    <input class="search-input" value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索部门、主管、状态、排序" />
  </view>

  <view wx:if="{{departments.length === 0}}" class="empty-state">
    <view class="empty-title">暂无匹配部门</view>
    <view class="empty-desc">可调整关键词或新增部门。</view>
  </view>

  <view wx:for="{{departments}}" wx:key="id" class="card dept-card">
    <view class="dept-top">
      <view>
        <view class="dept-name">{{item.sort}}. {{item.name}}</view>
        <view class="muted">主管：{{item.managers}}</view>
      </view>
      <view class="tag {{item.status === '停用' ? 'disabled' : ''}}">{{item.status}}</view>
    </view>
    <view class="actions">
      <button size="mini" class="ghost-btn" data-id="{{item.id}}" bindtap="editDepartment">编辑</button>
      <button size="mini" class="danger-btn" data-id="{{item.id}}" bindtap="toggleStatus">{{item.status === '启用' ? '停用' : '启用'}}</button>
    </view>
  </view>
</view>
<bottom-nav />
