.perm-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}
.perm-row:last-child { border-bottom: none; }
.perm-label { font-size: 14px; color: #333; }
.perm-value { font-size: 13px; padding: 2px 10px; border-radius: 12px; }
.perm-value.granted { background: #e8f5e9; color: #2e7d32; }
.perm-value.denied { background: #f5f5f5; color: #999; }
