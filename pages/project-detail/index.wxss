.project-no,
.device-no,
.qb-no {
  color: #0b7a75;
  font-size: 28rpx;
  font-weight: 700;
}

.project-name {
  font-size: 38rpx;
  font-weight: 800;
  margin-top: 8rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  color: #4b5563;
  font-size: 25rpx;
  margin: 22rpx 0;
}

.summary {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  text-align: center;
  border-top: 1rpx solid #eef2f7;
  padding-top: 20rpx;
}

.summary-num {
  font-size: 34rpx;
  font-weight: 800;
  color: #0b7a75;
}

.summary-label {
  color: #6b7280;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin: 10rpx 0 20rpx;
}

.project-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-end;
  margin: -4rpx 0 18rpx;
}

.tab {
  padding: 10rpx 22rpx;
  background: #ffffff;
  border-radius: 999rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.tab.active {
  background: #0b7a75;
  color: #ffffff;
}

.state-card {
  padding: 36rpx 28rpx;
  background: #ffffff;
  border-radius: 8rpx;
  text-align: center;
}

.state-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.section-row,
.device-top,
.process-left {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  margin: 12rpx 0 18rpx;
}

.main-btn {
  margin: 0;
  background: #0b7a75;
  color: #ffffff;
  border-radius: 999rpx;
}

.ghost-btn {
  margin: 0;
  background: #e7f6f4;
  color: #0b7a75;
  border-radius: 999rpx;
}

.danger-btn {
  margin: 0;
  background: #fee2e2;
  color: #b91c1c;
  border-radius: 999rpx;
}

.device-top {
  margin-bottom: 12rpx;
}

.device-area {
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.device-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 18rpx;
}

.process-list {
  margin: 22rpx 0;
  border-top: 1rpx solid #eef2f7;
}

.process-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.process-left {
  justify-content: flex-start;
  gap: 14rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d1d5db;
}

.dot.done {
  background: #059669;
}

.dot.doing {
  background: #2563eb;
}

.dot.late {
  background: #dc2626;
}

.process-name {
  font-size: 28rpx;
  font-weight: 700;
}

.process-meta {
  color: #6b7280;
  font-size: 23rpx;
  margin-top: 4rpx;
}

.status {
  color: #6b7280;
  font-size: 24rpx;
}

.qb-title,
.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 10rpx 0 14rpx;
}

.qb-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.attachment-add {
  margin-top: 18rpx;
}

.attachment-row,
.attachment-main {
  display: flex;
  align-items: center;
}

.attachment-row {
  justify-content: space-between;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.attachment-row:last-child {
  border-bottom: none;
}

.attachment-main {
  flex: 1;
  min-width: 0;
  gap: 12rpx;
}

.attachment-icon {
  flex: 0 0 auto;
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
  background: #e7f6f4;
  color: #0b7a75;
  font-size: 22rpx;
  font-weight: 700;
}

.attachment-name {
  max-width: 430rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 26rpx;
  font-weight: 700;
}

.remove-btn {
  margin: 0;
  background: #fee2e2;
  color: #b91c1c;
  border-radius: 999rpx;
}




.att-meta-row { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.att-cat-tag { font-size: 10px; padding: 1px 6px; border-radius: 8px; background: #e8f5e9; color: #2e7d32; white-space: nowrap; }
.upload-progress { margin-top: 8px; }
.progress-text { font-size: 12px; color: #666; margin-bottom: 4px; }
.upload-bar { margin-top: 10px; padding-top: 8px; border-top: 1px dashed #e0e0e0; }
.cloud-mark { color: #0B7A75; font-weight: 500; }
